{
  "name": "@timbenniks/contentstack-endpoints",
  "version": "3.0.2",
  "description": "A utility package to get Contentstack API endpoints based on cloud and region",
  "keywords": [
    "api",
    "cms",
    "contentstack",
    "endpoints",
    "headless",
    "headless-cms"
  ],
  "homepage": "https://github.com/timbenniks/contentstack-endpoints#readme",
  "bugs": {
    "url": "https://github.com/timbenniks/contentstack-endpoints/issues"
  },
  "license": "MIT",
  "author": "Tim Benniks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timbenniks/contentstack-endpoints.git"
  },
  "files": [
    "dist",
    "src/regions-metadata.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "test": "vp test run",
    "test:watch": "vp test",
    "generate-endpoints": "node scripts/generate-endpoints.js",
    "prepublishOnly": "npm run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.8.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.12.1"
}
